# Google Drive programme library (The Church in Tema)
GOOGLE_DRIVE_FOLDER_ID=17G-YzPxBMj41bpxCJoRhz4Rp7vGubrDZ
GOOGLE_API_KEY=

# Google Cloud Text-to-Speech (document uploads + DJ)
# Enable: https://console.cloud.google.com/apis/library/texttospeech.googleapis.com
# Can reuse GOOGLE_API_KEY if the key is allowed to call Text-to-Speech
GOOGLE_TTS_API_KEY=
# Optional defaults
GOOGLE_TTS_VOICE=en-US-Neural2-F
GOOGLE_TTS_LANG=en-US

# Optional durable store for uploads (shared across all listeners)
# Vercel → Storage → Blob
BLOB_READ_WRITE_TOKEN=
